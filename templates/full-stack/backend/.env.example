# Database — Supabase Postgres connection string
# Find this in: Supabase Dashboard > Settings > Database > Connection string (URI)
# Use the "Session pooler" URL for serverless; "Direct connection" for long-running servers.
DATABASE_URL=postgresql+asyncpg://postgres:your-password@db.your-project.supabase.co:5432/postgres

# CORS — comma-separated list of frontend origins allowed to call this API
CORS_ORIGINS=http://localhost:3000

# Set to true to enable SQL query logging (development only)
DEBUG=false
